{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://velostra.xyz/schemas/mainnet-readiness-packet.schema.json",
  "title": "Velostra Mainnet Readiness Packet",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "stage",
    "generatedAt",
    "release",
    "network",
    "repository",
    "plans",
    "controls",
    "gates",
    "decision",
    "blockers",
    "authorization",
    "integrity"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "velostra-mainnet-readiness-packet" },
    "stage": { "const": "preparation" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "release": { "type": "string", "pattern": "^[a-fA-F0-9]{40}$" },
    "network": { "type": "object" },
    "repository": { "type": "object" },
    "plans": {
      "type": "object",
      "required": ["environmentIsolation", "authority", "deployment", "canary"],
      "properties": {
        "environmentIsolation": { "type": "object" },
        "authority": { "type": "object" },
        "deployment": { "type": "object" },
        "canary": { "type": "object" }
      },
      "additionalProperties": false
    },
    "controls": { "type": "object" },
    "gates": {
      "type": "object",
      "required": [
        "environmentIsolation",
        "independentAudit",
        "authorityAndCustody",
        "deploymentPlanSafe",
        "canaryPolicySafe",
        "productionOperations",
        "twoPersonApprovalRoles"
      ],
      "properties": {
        "environmentIsolation": { "type": "boolean" },
        "independentAudit": { "type": "boolean" },
        "authorityAndCustody": { "type": "boolean" },
        "deploymentPlanSafe": { "type": "boolean" },
        "canaryPolicySafe": { "type": "boolean" },
        "productionOperations": { "type": "boolean" },
        "twoPersonApprovalRoles": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "decision": { "enum": ["NO_GO", "READY_FOR_SIGNING"] },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "authorization": {
      "type": "object",
      "required": ["mainnetBroadcast", "canaryExecution", "expansion"],
      "properties": {
        "mainnetBroadcast": { "const": false },
        "canaryExecution": { "const": false },
        "expansion": { "const": false }
      },
      "additionalProperties": false
    },
    "integrity": { "type": "object" }
  },
  "additionalProperties": false
}