# Copy to server.env only in the deployment secret/config store. Never commit server.env.
NODE_ENV=production
VELOSTRA_SECRET_PROVIDER=managed-injection
VELOSTRA_ENVIRONMENT=staging
VELOSTRA_RELEASE=git-sha-or-image-digest
PORT=8787
TRUST_PROXY=1
WEB_ORIGIN=https://staging.example.invalid
AUTH_PUBLIC_URI=https://staging.example.invalid
JSON_BODY_LIMIT=64kb

# Managed state. Require TLS and least-privilege service credentials.
DATABASE_URL=postgresql://service-account:secret@managed-postgres.invalid:5432/velostra_staging?sslmode=require
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
REDIS_URL=rediss://service-account:secret@managed-redis.invalid:6380
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_FAILURE_MODE=closed
AUTH_NONCE_STORE=redis

# Managed secret references are resolved by the platform before process start.
JWT_SECRET=replace-with-at-least-32-random-characters
GATEWAY_HMAC_SECRET=replace-with-at-least-32-random-characters
AGENT_SECRET_ENCRYPTION_KEY=base64-or-hex-encoded-32-byte-key
AGENT_SECRET_ENCRYPTION_KEY_ID=staging-primary
AGENT_SECRET_DECRYPTION_KEYS=
ADMIN_BOOTSTRAP_WALLETS=0xYourStagingGovernanceWallet

# Isolated staging chain deployment. Never insert a mainnet signer or treasury here.
ROBINHOOD_RPC_URL=https://dedicated-staging-rpc.example.invalid
ROBINHOOD_CHAIN_ID=4663
VELOSTRA_ESCROW_ADDRESS=0xYourIsolatedStagingEscrow
VELOSTRA_DEPLOYMENT_BLOCK=1
SETTLEMENT_SIGNER_MODE=remote
SETTLEMENT_SIGNER_URL=https://restricted-signer.example.invalid/v1/transactions
SETTLEMENT_SIGNER_AUTH_TOKEN=replace-via-managed-secret-store
SETTLEMENT_SIGNER_ADDRESS=0xYourRestrictedStagingSigner
SETTLEMENT_SIGNER_TIMEOUT_MS=10000
ONCHAIN_SETTLEMENT_MODE=required
SETTLEMENT_TOKEN_DECIMALS=6
ROBINHOOD_RPC_TIMEOUT_MS=10000

AGENT_TIMEOUT_MS=30000
AGENT_ALLOWED_PORTS=443
AGENT_MAX_REDIRECTS=2
AGENT_MAX_RESPONSE_BYTES=1048576
FREE_TIER_CALLS_PER_MONTH=10

RECONCILE_INTERVAL_MS=30000
RECONCILE_OUTBOX_GRACE_MS=120000
RECONCILE_MAX_BLOCK_RANGE=2000
RECONCILE_CONFIRMATIONS=12
RECONCILE_RPC_RETRIES=3
RECONCILE_RPC_RETRY_BASE_MS=1000
RECONCILE_DRIFT_THRESHOLD=0.000001
