ROBINHOOD_CHAIN_ID=46630
VELOSTRA_ESCROW_ADDRESS=0xYourIsolatedStagingEscrow
SETTLEMENT_SIGNER_ADDRESS=0xAddressDerivedFromCloudKmsPublicKey
SETTLEMENT_SIGNER_AUTH_TOKEN=replace-via-managed-secret-store
GOOGLE_CLOUD_KMS_KEY_VERSION=projects/velostra-staging/locations/us-east4/keyRings/velostra-staging/cryptoKeys/settlement-signer/cryptoKeyVersions/1
SIGNER_INTENT_TTL_SECONDS=2592000
SIGNER_NONCE_LOCK_MS=30000
SIGNER_LOCK_WAIT_MS=5000
SIGNER_MAX_GAS=500000
SIGNER_MAX_FEE_PER_GAS_WEI=10000000000