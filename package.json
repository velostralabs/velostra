{
  "name": "velostra",
  "private": true,
  "version": "0.1.0",
  "description": "Verified AI execution marketplace with transparent per-call pricing, onchain settlement, and self-healing reconciliation.",
  "author": {
    "name": "Velostra",
    "url": "https://github.com/velostralabs"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velostralabs/velostra.git"
  },
  "homepage": "https://github.com/velostralabs/velostra#readme",
  "bugs": {
    "url": "https://github.com/velostralabs/velostra/issues"
  },
  "keywords": [
    "ai-agents",
    "agent-marketplace",
    "onchain-settlement",
    "reconciliation",
    "evm",
    "react",
    "typescript",
    "solidity"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test:browser": "npm run build:browser-fixture && npm run performance:build && playwright test",
    "test:browser:update": "npm run build:browser-fixture && playwright test tests/browser/accessibility-visual.spec.ts --update-snapshots",
    "test:wallet:metamask": "playwright test tests/browser/metamask.external.spec.ts --workers=1",
    "test:performance": "npm run build:browser-fixture && npm run performance:build && playwright test tests/browser/performance.spec.ts",
    "performance:build": "node scripts/check-performance-budget.mjs",
    "audit:metamask": "node scripts/check-metamask-advisory-reachability.mjs",
    "phase2:load": "node scripts/run-phase2-load.mjs",
    "phase2:soak": "node scripts/run-phase2-soak.mjs",
    "phase2:evidence": "node scripts/validate-phase2-evidence.mjs",
    "test:phase2-evidence": "node --check scripts/run-phase2-load.mjs && node --check scripts/run-phase2-soak.mjs && node scripts/test-phase2-evidence.mjs",
    "release:prepare": "npm run build --prefix contracts && node scripts/prepare-phase3-release.mjs",
    "release:validate": "node scripts/validate-phase3-release.mjs",
    "test:phase3-release": "npm run build --prefix contracts && node scripts/test-phase3-release.mjs",
    "build:browser-fixture": "node scripts/build-browser-fixture.mjs"
  },
  "dependencies": {
    "@metamask/connect-evm": "^2.1.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.101.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1",
    "viem": "^2.55.1",
    "wagmi": "^3.7.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
