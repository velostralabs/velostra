NODE_ENV=development
VELOSTRA_SECRET_PROVIDER=local-env
VELOSTRA_ENVIRONMENT=local
VELOSTRA_RELEASE=development
DATABASE_URL="postgresql://user:password@localhost:5432/velostra"
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
JWT_SECRET="replace-with-a-long-random-string"
AUTH_PUBLIC_URI=http://localhost:5173
AUTH_NONCE_STORE=redis
ADMIN_BOOTSTRAP_WALLETS="0xYourGovernanceWalletAddress"
GATEWAY_HMAC_SECRET="replace-with-a-long-random-string"
AGENT_SECRET_ENCRYPTION_KEY=
AGENT_SECRET_ENCRYPTION_KEY_ID=primary
AGENT_SECRET_DECRYPTION_KEYS=
WEB_ORIGIN="http://localhost:5173"
TRUST_PROXY=false
JSON_BODY_LIMIT=64kb
PORT=8787
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_FAILURE_MODE=open
VELOSTRA_ESCROW_ADDRESS=
SETTLEMENT_SIGNER_MODE=local
BACKEND_SIGNER_PRIVATE_KEY=
SETTLEMENT_SIGNER_URL=
SETTLEMENT_SIGNER_AUTH_TOKEN=
SETTLEMENT_SIGNER_ADDRESS=
SETTLEMENT_SIGNER_TIMEOUT_MS=10000
SETTLEMENT_TOKEN_DECIMALS=6
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_RPC_FALLBACK_URLS=
ROBINHOOD_CHAIN_ID=4663
ONCHAIN_SETTLEMENT_MODE=required
AGENT_TIMEOUT_MS=30000
AGENT_ALLOWED_PORTS=80,443
AGENT_MAX_REDIRECTS=2
AGENT_MAX_RESPONSE_BYTES=1048576
AGENT_SSRF_TEST_ALLOW_LOOPBACK=false
FREE_TIER_CALLS_PER_MONTH=10
ROBINHOOD_RPC_TIMEOUT_MS=10000
VELOSTRA_DEPLOYMENT_BLOCK=0
RECONCILE_INTERVAL_MS=30000
RECONCILE_OUTBOX_GRACE_MS=120000
RECONCILE_MAX_BLOCK_RANGE=2000
RECONCILE_CONFIRMATIONS=12
RECONCILE_RPC_RETRIES=3
RECONCILE_RPC_RETRY_BASE_MS=1000
RECONCILE_DRIFT_THRESHOLD=0.000001

# Phase 4 platform and durable webhook delivery
PLATFORM_CURSOR_SECRET="replace-with-at-least-32-random-characters"
WEBHOOK_BATCH_SIZE=25
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_RETRY_BASE_MS=1000
WEBHOOK_RETRY_MAX_MS=3600000
WEBHOOK_LOCK_MS=60000
WEBHOOK_INTERVAL_MS=5000

# Phase 2 observability and alerting
METRICS_AUTH_TOKEN=
OBSERVABILITY_INTERVAL_MS=15000
READINESS_REQUIRE_WORKER=false
READINESS_WORKER_MAX_AGE_MS=90000
READINESS_REQUIRE_WEBHOOK_WORKER=false
READINESS_WEBHOOK_WORKER_MAX_AGE_MS=90000
MONITOR_INTERVAL_MS=30000
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TOKEN=
ALERT_WEBHOOK_TIMEOUT_MS=5000
ALERT_RUNBOOK_BASE_URL=
ALERT_REPEAT_SECONDS=1800
ALERT_WORKER_MAX_AGE_SECONDS=90
ALERT_REQUIRE_WEBHOOK_HEARTBEAT=false
ALERT_WEBHOOK_WORKER_MAX_AGE_SECONDS=90
ALERT_WEBHOOK_MAX_PENDING_AGE_SECONDS=300
ALERT_CURSOR_LAG_BLOCKS=2000
ALERT_OUTBOX_MAX_AGE_SECONDS=300
ALERT_SIGNER_MIN_BALANCE_WEI=10000000000000000
ALERT_REQUIRE_BACKUP_HEARTBEAT=false
ALERT_BACKUP_MAX_AGE_SECONDS=86400
