NODE_ENV=development
DATABASE_URL="postgresql://user:password@localhost:5432/velostra"
JWT_SECRET="replace-with-a-long-random-string"
AUTH_PUBLIC_URI=http://localhost:5173
AUTH_NONCE_STORE=redis
ADMIN_WALLET="0xYourAdminWalletAddress"
GATEWAY_HMAC_SECRET="replace-with-a-long-random-string"
WEB_ORIGIN="http://localhost:5173"
TRUST_PROXY=false
JSON_BODY_LIMIT=64kb
PORT=8787
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_FAILURE_MODE=open
VELOSTRA_ESCROW_ADDRESS=
BACKEND_SIGNER_PRIVATE_KEY=
SETTLEMENT_TOKEN_DECIMALS=6
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_CHAIN_ID=4663
ONCHAIN_SETTLEMENT_MODE=required
AGENT_TIMEOUT_MS=30000
AGENT_ALLOWED_PORTS=80,443
AGENT_MAX_REDIRECTS=2
AGENT_MAX_RESPONSE_BYTES=1048576
AGENT_SSRF_TEST_ALLOW_LOOPBACK=false
FREE_TIER_CALLS_PER_MONTH=10
ROBINHOOD_RPC_TIMEOUT_MS=10000
VELOSTRA_DEPLOYMENT_BLOCK=0
RECONCILE_INTERVAL_MS=30000
RECONCILE_MAX_BLOCK_RANGE=2000
RECONCILE_CONFIRMATIONS=12
RECONCILE_RPC_RETRIES=3
RECONCILE_RPC_RETRY_BASE_MS=1000
RECONCILE_DRIFT_THRESHOLD=0.000001
