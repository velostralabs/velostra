{
  "name": "@velostra/server",
  "private": true,
  "version": "0.1.0",
  "description": "Velostra gateway, marketplace API, financial ledger, and chain reconciliation worker.",
  "author": {
    "name": "Velostra",
    "url": "https://github.com/velostralabs"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/velostralabs/velostra.git",
    "directory": "server"
  },
  "homepage": "https://github.com/velostralabs/velostra/tree/main/server",
  "bugs": {
    "url": "https://github.com/velostralabs/velostra/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:signer": "node dist/signer/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test:auth": "tsx test/auth.e2e.test.ts",
    "test:ssrf": "tsx test/ssrf.e2e.test.ts",
    "test:http-security": "tsx test/http-security.e2e.test.ts",
    "test:config": "tsx test/production-config.test.ts",
    "test:phase3-canary": "tsx test/phase3-canary.test.ts",
    "test:phase3-canary-db": "tsx test/phase3-canary-db.e2e.test.ts",
    "test:phase4-platform": "tsx test/phase4-platform.test.ts",
    "test:phase4-e2e": "tsx test/phase4-platform.e2e.test.ts",
    "test:secrets": "tsx test/secrets.e2e.test.ts",
    "test:admin-policy": "tsx test/admin-policy.test.ts",
    "test:money-unit": "tsx test/money.test.ts",
    "test:migrations": "tsx test/migrations.e2e.test.ts",
    "restore:verify": "tsx scripts/verify-restore.ts",
    "test:platform": "tsx test/platform.e2e.test.mjs",
    "test:money": "npm --prefix ../contracts run build && tsx test/money-loop.e2e.test.mjs",
    "secrets:reencrypt": "tsx scripts/reencrypt-agent-secrets.ts",
    "reconcile": "tsx src/jobs/reconcile.ts --once",
    "reconcile:worker": "tsx src/jobs/reconcile.ts --watch",
    "webhooks": "tsx src/jobs/webhooks.ts",
    "webhooks:worker": "tsx src/jobs/webhooks.ts --watch",
    "db:migrate:runtime": "node dist/scripts/migrate.js",
    "test:signer": "tsx test/remote-signer.test.ts",
    "test:kms-signer": "tsx test/kms-signer.test.ts",
    "kms:address": "tsx src/scripts/derive-kms-address.ts",
    "test:authority": "tsx test/authority-policy.test.ts",
    "authority:validate": "tsx src/scripts/validate-authority-policy.ts",
    "monitor": "tsx src/jobs/monitor.ts",
    "monitor:worker": "tsx src/jobs/monitor.ts --watch",
    "alert:ack": "tsx src/scripts/acknowledge-alert.ts",
    "test:observability": "tsx test/observability.test.ts",
    "test:resilience": "tsx test/rpc-resilience.test.ts && tsx test/chain-policy.test.ts",
    "test:synthetic-agent": "tsx test/synthetic-agent.test.ts",
    "test:observability-db": "tsx test/observability-db.e2e.test.ts",
    "heartbeat:record": "tsx src/scripts/record-heartbeat.ts",
    "phase3:snapshot": "tsx src/scripts/capture-phase3-readiness.ts",
    "phase3:canary-summary": "tsx src/scripts/capture-phase3-canary.ts",
    "staging:reconciliation-evidence": "node scripts/capture-staging-reconciliation.mjs"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "ioredis": "^5.11.1",
    "jose": "^5.9.0",
    "nanoid": "^5.0.7",
    "pg": "^8.22.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "ganache": "^7.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
